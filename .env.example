# ======================================================================
# Infrastructure Management Dashboard — Community Edition
#
# The onboard script (scripts/Onboard-Dashboard.ps1 or scripts/onboard.sh)
# copies this file to `.env` and auto-generates the secrets below.
#
# Cloud credentials (AWS, Azure) and feature flags are configured through
# the browser setup wizard on first launch — you do NOT need to fill them
# in here.
# ======================================================================


# === Bootstrap secrets (auto-generated by the onboard script) =========

# JWT_SECRET_KEY is NOT stored here. The onboard script generates a strong
# random value and writes it to .jwt_secret_key (owner-read-only, Docker
# secret mount). Keeping it out of .env means this file is safe to inspect
# for debugging without exposing the root-of-trust for encrypted secrets.
#
# Running without Docker Compose (e.g. bare uvicorn in CI)?
# Set JWT_SECRET_KEY=<hex> in the environment directly, or point
# JWT_SECRET_KEY_FILE at a file containing the key.

# PostgreSQL password for the Docker Compose `db` service.
# The onboard script generates a strong random value on first run.
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD

# Environment name — leave as "development" for local Docker Desktop use.
APP_ENV=development


# === Optional: WebAuthn / FIDO2 MFA ====================================
#
# Leave at defaults for local dev (localhost is exempt from HTTPS).
# Change only when you expose the dashboard on a real domain.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Infrastructure Management Dashboard
WEBAUTHN_ORIGIN=http://localhost:8001


# === Optional: background job worker scaling =========================
#
# Long jobs (k8s / cloud-DB provisions, Packer builds, image export &
# promote) run in the dedicated `worker` container, NOT the web app.
# Each worker runs ONE such job at a time, so WORKER_REPLICAS is the
# number that can run concurrently — the default is 3; drop it toward 1 on
# small hosts, or raise it if quick jobs still queue behind long ones. The
# per-worker CPU/memory limits bound aggregate host usage when several heavy
# jobs run at once (3 busy workers can use up to ~3× these limits); tune to your host.
#
# Takes effect on the next `scripts/onboard.sh` / `docker compose up -d`.
# Ad-hoc override without editing .env: docker compose up -d --scale worker=N
WORKER_REPLICAS=3
WORKER_CPU_LIMIT=2
WORKER_MEM_LIMIT=2g
