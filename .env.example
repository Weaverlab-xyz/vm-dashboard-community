# ======================================================================
# Infrastructure Management Dashboard — Community Edition
#
# Copy this file to `.env` (scripts/Onboard-Dashboard.ps1 does this for
# you on first run), then fill in the REPLACE_ME values below.
#
# Lines starting with `# === Required ===` must be filled in.
# Lines starting with `# === Optional ===` can stay at their defaults.
# ======================================================================


# === Required: Core app ================================================
#
# JWT_SECRET_KEY is auto-generated on first run by Onboard-Dashboard.ps1.
# If you prefer to set it yourself, generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_ME_WITH_32_BYTE_HEX

# PostgreSQL password for the Docker-Compose `db` service.
# Onboard-Dashboard.ps1 will generate a strong value on first run.
# docker-compose.yml assembles DATABASE_URL from this value, so you only
# need to set this one variable; the app picks it up automatically.
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD

# First-run dashboard admin account. On first startup — when the users table
# is empty — the app creates this account from the values below. Subsequent
# startups are no-ops, so changing the password here later has no effect
# (reset through the app's settings UI instead). Onboard-Dashboard.ps1 will
# generate a strong password on first run.
FIRST_RUN_ADMIN_USERNAME=admin
FIRST_RUN_ADMIN_PASSWORD=REPLACE_ME_WITH_ADMIN_PASSWORD

# Environment name; leave as "development" for local Docker Desktop use.
APP_ENV=development


# === Required: AWS =====================================================
#
# The dashboard deploys EC2 instances into *your* AWS account. Create an
# IAM user dedicated to the dashboard with these managed policies attached:
#   - AmazonEC2FullAccess
#   - AmazonS3ReadOnlyAccess
#   - IAMReadOnlyAccess
# Then create an access key for that user and paste it below.
#
# Quick setup (AWS CLI, one-shot):
#   aws iam create-user --user-name dashboard-dev
#   aws iam attach-user-policy --user-name dashboard-dev --policy-arn arn:aws:iam::aws:policy/AmazonEC2FullAccess
#   aws iam attach-user-policy --user-name dashboard-dev --policy-arn arn:aws:iam::aws:policy/AmazonS3ReadOnlyAccess
#   aws iam attach-user-policy --user-name dashboard-dev --policy-arn arn:aws:iam::aws:policy/IAMReadOnlyAccess
#   aws iam create-access-key --user-name dashboard-dev
AWS_ACCESS_KEY_ID=REPLACE_ME_WITH_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_ME_WITH_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-2


# === Required: Azure (resource management) =============================
#
# The dashboard deploys Azure VMs into *your* Azure subscription using a
# service principal with Contributor rights. Create one with:
#
#   az ad sp create-for-rbac --name "dashboard-dev" --role Contributor
#     --scopes /subscriptions/<your-subscription-id>
#
# Run the two lines above joined as one command; see docs/ONBOARDING.md Part B.
#
# Copy the output's `appId`, `password`, `tenant` into the three slots
# below. Add your subscription id separately (az account show --query id).
AZURE_CLIENT_ID=REPLACE_ME_WITH_AZURE_APP_ID
AZURE_CLIENT_SECRET=REPLACE_ME_WITH_AZURE_CLIENT_SECRET
AZURE_TENANT_ID=REPLACE_ME_WITH_AZURE_TENANT_ID
AZURE_SUBSCRIPTION_ID=REPLACE_ME_WITH_AZURE_SUBSCRIPTION_ID

# Default resource group + region for deployed VMs. The RG is created
# on first deploy if it does not exist.
AZURE_RESOURCE_GROUP=dashboard-rg
AZURE_LOCATION=centralus


# === Optional: Sign in with Microsoft (Azure AD OAuth) =================
#
# Leave blank to use the local username/password login only. To enable
# OAuth, create a SECOND Azure app registration (separate from the
# resource-management SP above):
#
#   1. Azure Portal → App registrations → New registration
#        Name: "Dashboard OAuth (dev)"
#        Supported account types: single-tenant
#   2. Authentication → Add platform → Web
#        Redirect URI: http://localhost:8000/api/auth/oauth/azure/callback
#   3. API permissions → Add → Microsoft Graph → Delegated → openid, profile, email
#   4. Certificates & secrets → New client secret
#   5. Paste the values below.
AZURE_OAUTH_CLIENT_ID=
AZURE_OAUTH_CLIENT_SECRET=
AZURE_OAUTH_TENANT_ID=
AZURE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/oauth/azure/callback

# Optional: map Entra group object ids to dashboard workgroups. JSON dict.
# Users in any listed group are auto-created on first login.
# Example: {"11111111-...":"Team-A","22222222-...":"Team-B"}
AZURE_OAUTH_GROUP_MAP={}


# === Optional: WebAuthn / FIDO2 MFA ====================================
#
# Leave these at the defaults for local dev (localhost is exempt from the
# HTTPS requirement). If you expose the dashboard on a real domain, set
# WEBAUTHN_RP_ID to the bare domain and WEBAUTHN_ORIGIN to the full URL.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Infrastructure Management Dashboard
WEBAUTHN_ORIGIN=http://localhost:8000


# === Optional: Natural-language chat assistant (Ollama) ================
#
# A local Ollama container is included in docker-compose.yml. Set
# CHAT_ENABLED=true to turn on the chat UI. The first request after
# startup pulls the model (~5 GB for the default 8B model); expect a
# delay on cold start.
CHAT_ENABLED=false
OLLAMA_BASE_URL=http://ollama:11434
CHAT_MODEL=llama3.1:8b-instruct-q4_K_M


# === Feature flags (all default OFF in the community edition) ==========
#
# These gate optional integrations. The community edition ships with all
# of them off. Enable only if you have the backing infrastructure.
#
# - VMWARE_ENABLED: VMware Workstation VM management. Windows host only.
#   Requires VMware Workstation installed + SSH from the container to the
#   host. See docs/ONBOARDING.md Appendix A.
# - BEYONDTRUST_ENABLED: BeyondTrust PRA integration for secret retrieval
#   and session recording. Requires a BeyondTrust tenant.
# - PORTAINER_ENABLED: Portainer CE for on-prem Docker host management.
# - ANSIBLE_ENABLED: Ansible-based config management via local Docker or
#   AWS ECS Fargate.
# - ENTITLE_ENABLED: Entitle approval-workflow integration for gated
#   actions. Leave off unless you have an Entitle tenant.
VMWARE_ENABLED=false
BEYONDTRUST_ENABLED=false
PORTAINER_ENABLED=false
ANSIBLE_ENABLED=false
ENTITLE_ENABLED=false
