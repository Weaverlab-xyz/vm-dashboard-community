# ── Optional Windows + VMware Workstation overrides ─────────────────────
#
# Copy this file to docker-compose.override.windows.yml (without the
# .example suffix) to enable VMware Workstation VM management from the
# dashboard.
#
# Prerequisites on the host:
#   1. Windows with VMware Workstation installed.
#   2. SSH access to the host from the container — run
#      scripts/Setup-DevSsh.ps1 first to generate the key at
#      %USERPROFILE%\.ssh\dev_dashboard_key.
#   3. Set VMWARE_ENABLED=true and SSH_USER=<your windows username> in .env.
#
# Apply by adding -f flags to every compose invocation:
#   docker compose -f docker-compose.yml -f docker-compose.override.windows.yml up -d
#
# Or rename this to docker-compose.override.yml (compose auto-loads any
# file with that exact name — no flag needed), but be aware that the
# override then applies on every `docker compose` command including ones
# you may not want it on.

services:
  app:
    extra_hosts:
      # Container needs to reach the Windows host on its loopback to SSH in.
      - "host.docker.internal:host-gateway"
    environment:
      # Mode flag for the PowerShell service layer.
      - POWERSHELL_EXECUTION_MODE=ssh
      # Path inside the container where the SSH key is bind-mounted below.
      - SSH_KEY_FILE=/root/.ssh/dev_key
      # Absolute path on the HOST to the dashboard's PowerShell wrapper —
      # SSH sessions run it on the Windows side, not in the container.
      # Adjust to match where you cloned the repo.
      - VM_CLI_WRAPPER_PATH=C:\Scripts\vm-dashboard-community\vm_cli_api_wrapper.ps1
    volumes:
      # Bind-mount the SSH private key generated by Setup-DevSsh.ps1.
      # USERPROFILE is provided by Docker Desktop on Windows.
      - type: bind
        source: ${USERPROFILE}/.ssh/dev_dashboard_key
        target: /root/.ssh/dev_dashboard_key
        read_only: true
