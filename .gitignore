# Terraform — never commit state or tfvars with credentials
terraform.tfvars
*.tfvars
!*.tfvars.example
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfplan

# Terraform deployment scratch (per-job subdirs created at runtime)
terraform/deployments/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
web_dashboard/venv/
*.egg-info/
dist/
build/

# Local secrets — generated by the onboard script, never committed
.env
.jwt_secret_key
docker-compose.override.yml
docker-compose.override.windows.yml
!.env.example
!docker-compose.override.windows.yml.example
*.pem
*.key
*.p12
*.pfx

# Local SQLite fallback (production uses Postgres via Docker Compose)
*.db
*.sqlite3

# Logs
*.log
logs/

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
sa-key.json

# Corporate proxy root CA — drop .crt/.pem files into corp-ca/ for the
# Dockerfile to pick up. Contents are local to each developer's network.
corp-ca/*
!corp-ca/.gitkeep
!corp-ca/README.md
