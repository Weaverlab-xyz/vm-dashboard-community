# Secrets — must never be baked into the image
.env
.jwt_secret_key
*.pem
*.key
*.p12
*.pfx

# Allow corp proxy root CA bundle into the build context. The Dockerfile
# trusts any .crt/.pem files in corp-ca/ so builds work behind TLS-inspecting
# proxies (Cloudflare Gateway, Zscaler, etc.). This must come after *.pem
# so the exception takes effect.
!corp-ca

# Git history
.git/

# Terraform (not needed inside the container) — except the static cloud-database
# + k8s-cluster modules, which cloud_database_service / k8s_service drive with
# `terraform apply`. Each module the Dockerfile COPYs must be re-included here, or
# the COPY resolves to an empty source and the build fails.
terraform/*
!terraform/db_postgres
!terraform/db_azure_postgres
!terraform/db_gcp_postgres
!terraform/db_mysql
!terraform/db_azure_mysql
!terraform/db_gcp_mysql
!terraform/db_sqlserver
!terraform/db_gcp_sqlserver
!terraform/db_azure_sqlserver
!terraform/k8s_cluster
# Admission-control Rego policies — read at runtime by admission_service (the
# pre-action guardrails). COPYed by the Dockerfile, so must be in the context.
!terraform/policy
*.tfstate
*.tfstate.*
*.tfvars
.terraform/

# Python build artefacts
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Scripts aren't needed at runtime. docs/ IS now shipped — it's rendered at
# /docs/<page> by api/docs_pages.py (the in-app guide links), so it must stay
# in the build context (markdown only; small).
scripts/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
